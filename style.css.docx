body {
  margin: 0;
  font-family: Arial, sans-serif;
  line-height: 1.6;
  color: #222;
  background-color: #f7f9fc;
}

.container {
  width: 90%;
  max-width: 1100px;
  margin: auto;
}

header {
  background: #0b3d5c;
  color: white;
  padding: 25px 0;
  text-align: center;
}

header h1 {
  margin: 0;
}

header p {
  margin: 5px 0 15px;
}

nav a {
  color: white;
  text-decoration: none;
  margin: 0 12px;
  font-weight: bold;
}

.hero {
  background: #dfeff5;
  text-align: center;
  padding: 80px 20px;
}

.hero h2 {
  font-size: 2rem;
}

.btn {
  display: inline-block;
  margin-top: 20px;
  background: #0b3d5c;
  color: white;
  padding: 12px 24px;
  text-decoration: none;
  border-radius: 6px;
}

.section {
  padding: 60px 20px;
}

.light {
  background: white;
}

.cards {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 20px;
}

.card {
  background: #eef4f8;
  padding: 20px;
  border-radius: 8px;
}

footer {
  background: #0b3d5c;
  color: white;
  text-align: center;
  padding: 20px 0;
}